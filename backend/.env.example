# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (required in production). Neon, Supabase, and Railway all provide
# a connection string in this format. The app normalises postgres:// → psycopg.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ── Internal auth ─────────────────────────────────────────────────────────────
# Shared secret between the Next.js frontend and this backend.
# Must be ≥24 characters. Generate with: openssl rand -hex 24
# Set the SAME value as BACKEND_INTERNAL_API_KEY in the frontend environment.
BACKEND_INTERNAL_API_KEY=replace-with-a-long-random-secret

# A2: verifies the short-lived actor token minted by the Next proxy, proving
# a request's user id + role instead of trusting plain X-Actor-* headers.
# Must be ≥20 characters and match ACTOR_TOKEN_SECRET on the frontend.
ACTOR_TOKEN_SECRET=replace-with-a-long-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list or JSON array of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin seed account ────────────────────────────────────────────────────────
# Created automatically on first boot if the user does not already exist.
SEED_ADMIN_NAME=Spree Admin
SEED_ADMIN_EMAIL=admin@spree.local
SEED_ADMIN_PASSWORD=ChangeMe123!   # must be ≥12 chars in production

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Sign up at https://resend.com and add your API key here.
# If not set, email notifications are skipped (in-app still works).
# EMAIL_FROM must be set to the SAME value here and in the frontend's .env —
# a mismatch means one send path silently fails (see EMAIL_FLOW_ASSESSMENT_2026-07-10.md).
RESEND_API_KEY=re_...
# Sandbox sender — works with no domain verification, but only delivers to
# your Resend account's own email. Swap to Spree <no-reply@yourdomain.com>
# once a real domain is verified.
EMAIL_FROM=Spree <onboarding@resend.dev>

# ── Developer alerts ──────────────────────────────────────────────────────────
# If set, critical events (payment failures, payout failures) are emailed here.
# Requires RESEND_API_KEY to be configured.
# DEV_ALERT_EMAIL=dev@yourteam.com

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys once with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
# Or use: pywebpush --gen-vapid-keys
# If not set, push notifications are skipped (in-app + email still work).
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used to build CTAs in email notifications.
FRONTEND_URL=https://yourdomain.com

# ── Passkeys (WebAuthn) ───────────────────────────────────────────────────────
# A wrong RP ID/origin is the most common WebAuthn failure — both fall back to
# FRONTEND_URL above when unset (host-only for RP ID, full origin for
# WEBAUTHN_RP_ORIGIN), so these only need to be set explicitly if the
# frontend is ever served from a different host than FRONTEND_URL, or you
# want them spelled out rather than derived. Production values for this repo:
# WEBAUTHN_RP_ID=spreecommerce.vercel.app
# WEBAUTHN_RP_ORIGIN=https://spreecommerce.vercel.app
# WEBAUTHN_RP_NAME=Spree

# ── NIA Ghana Card verification (G4) ─────────────────────────────────────────
# If not set, adapter runs in mock mode (safe for development/staging).
# NIA_API_URL=https://api.nia.gov.gh/v1
# NIA_API_KEY=your-nia-api-key
# NIA_MOCK=true        # set to "false" in production to use live NIA API
# NIA_TIMEOUT_SECONDS=10

# ── Face liveness + ID photo match (G5) ──────────────────────────────────────
# If not set, adapter runs in mock mode.
# FACE_MATCH_API_URL=https://api.provider.com/v1
# FACE_MATCH_API_KEY=your-face-match-api-key
# FACE_MATCH_MOCK=true
# FACE_MATCH_MOCK_FAIL=false     # set to "true" to simulate a face-match failure
# FACE_LIVENESS_THRESHOLD=0.85
# FACE_MATCH_THRESHOLD=0.80
# FACE_MATCH_TIMEOUT_SECONDS=15

# ── Logistics / shipping (G7) ─────────────────────────────────────────────────
# If not set, adapter runs in mock mode.
# LOGISTICS_API_URL=https://api.carrier.gh/v1
# LOGISTICS_API_KEY=your-logistics-api-key
# LOGISTICS_WEBHOOK_SECRET=your-logistics-webhook-secret
# LOGISTICS_MOCK=true
# LOGISTICS_TIMEOUT_SECONDS=10

# ── Encryption (G13) ──────────────────────────────────────────────────────────
# Fernet key for field-level encryption of Ghana Card numbers, payout details,
# and document URLs.  Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=

# ── Stream Chat ───────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.getstream.io
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret
STREAM_ADMIN_USER_ID=spree-admin
# Webhook signing secret — copy from Stream dashboard → Webhooks → Signing Secret
STREAM_WEBHOOK_SECRET=your_webhook_signing_secret

# ── Anthropic / Claude AI (support chat auto-replies) ─────────────────────────
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | production
ENABLE_API_DOCS=true               # false in production by default
AUTO_INITIALIZE_DATABASE=true
LOG_LEVEL=INFO
UPLOADS_DIR=                       # leave blank to use /tmp/uploads on Vercel
