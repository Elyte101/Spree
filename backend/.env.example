ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://spree:spree@127.0.0.1:5432/spree
# CORS_ORIGINS supports a JSON array or a comma-separated list of origins.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Set these explicitly for deployed environments if you want the admin account auto-created.
SEED_ADMIN_NAME=Spree Admin
SEED_ADMIN_EMAIL=admin@spree.local
SEED_ADMIN_PASSWORD=ChangeMe123!
# Replace this in deployed environments.
INTERNAL_API_KEY=spree-internal-dev-key
AUTO_INITIALIZE_DATABASE=true
LOG_LEVEL=INFO
