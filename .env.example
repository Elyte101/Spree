# ---------------------------------------------------------------
# BACKEND CONNECTION
# ---------------------------------------------------------------
# Production (Vercel): set BACKEND_URL to your deployed API origin.
# Do NOT use a localhost value here — it will throw at runtime on Vercel.
# BACKEND_URL=https://api.yourdomain.com

# Local dev only — overrides BACKEND_URL if both are set:
BACKEND_API_URL=http://127.0.0.1:8000/api/v1

# Must match BACKEND_INTERNAL_API_KEY in backend/.env
BACKEND_INTERNAL_API_KEY=spree-internal-dev-key

# A2: signs the short-lived actor token that proves a request's user id +
# role to the backend. Must match ACTOR_TOKEN_SECRET in backend/.env.
# Generate with: openssl rand -hex 32
ACTOR_TOKEN_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------
# AUTH
# ---------------------------------------------------------------
# Production: set to your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-this-with-a-long-random-string

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=

# ---------------------------------------------------------------
# EMAIL (Resend) — optional until domain is verified
# ---------------------------------------------------------------
# RESEND_API_KEY=re_your_key_here
# EMAIL_FROM=Spree <noreply@yourdomain.com>

# ---------------------------------------------------------------
# PAYMENTS
# ---------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# ---------------------------------------------------------------
# STREAM CHAT
# ---------------------------------------------------------------
# Public key — safe to expose to the browser (used by stream-chat-react)
NEXT_PUBLIC_STREAM_API_KEY=your_stream_api_key
# STREAM_API_SECRET and STREAM_ADMIN_USER_ID are server-only — add them to backend/.env

# ---------------------------------------------------------------
# MOMO NAME ENQUIRY
# ---------------------------------------------------------------
# Provider for MoMo account-name verification.
# Options: paystack | flutterwave
# Leave unset to disable (UI falls back to manual name entry — no fake names generated)
# MOMO_PROVIDER=paystack

# Required when MOMO_PROVIDER=flutterwave
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...

# Required when MOMO_PROVIDER=paystack (PAYSTACK_SECRET_KEY is also used for checkout)
# PAYSTACK_SECRET_KEY=sk_test_...
